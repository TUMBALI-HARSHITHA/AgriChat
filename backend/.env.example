# AgriChat Backend Configuration

# Server Port
PORT=8000

# SQLite Database URL
DATABASE_URL=mongodb+srv://your_username:your_password@cluster.mongodb.net/agrichat?appName=Cluster0
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/agrichat?appName=Cluster0

# Optional: Google Gemini API Key for automatic advice generation
# Get a key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
