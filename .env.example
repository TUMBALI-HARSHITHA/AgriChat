# =========================================================================
# AgriChat Project - Environment Variables Configuration Template
# Copy this file to '.env' at the root and also inside the 'backend/' folder.
# =========================================================================

# --- DATABASE CONFIGURATION ---
# The connection URL for the real database.
# For SQLite: sqlite:///./backend/agrichat.db (Default local file-based database)
# For PostgreSQL: postgresql://username:password@hostname:5432/databasename
# For MongoDB: mongodb+srv://username:password@cluster.mongodb.net/dbname
DATABASE_URL=mongodb+srv://your_username:your_password@cluster.mongodb.net/agrichat?appName=Cluster0
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/agrichat?appName=Cluster0

# --- SERVER / API CONFIGURATION ---
# Port number for the FastAPI backend server
PORT=8000

# --- GOOGLE GEMINI API CONFIGURATION ---
# API Key for generating agricultural advice automatically.
# Get a free API key at: https://aistudio.google.com/apikey
# Note: VITE_ prefixed variables are loaded automatically by Vite in the frontend client.
VITE_GEMINI_API_KEY=your_gemini_api_key_placeholder
GEMINI_API_KEY=your_gemini_api_key_placeholder
